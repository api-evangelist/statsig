      "name": "Initialization",
      "description": {
        "content": "Endpoints for initializing client SDKs with all evaluated feature gates, configs, experiments, and layers for a given user.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "750f0d3a-d39d-4f67-9268-eb48271b8eb4",
          "name": "Initialize client SDK",
          "request": {
            "name": "Initialize client SDK",
            "description": {
              "content": "Returns all evaluated gates, configs, experiments, and layers for a given user. This is the primary endpoint called during client SDK initialization. The response contains hashed entity names for security, and the client SDK decodes them locally. The response is optimized for client-side caching and includes a hash for detecting changes on subsequent requests.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "initialize"
              ],
              "host": [
                "{{baseUrl}}"
